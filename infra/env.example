# Claude Code VM Supervisor — Environment Configuration
# Copy to ~/.config/claude-vm/env and fill in real values.
# Required vars are marked with (required); the rest have working defaults.

# ─── Lark App Credentials ─────────────────────────────────────────────────────

# (required) Lark app ID from the Lark developer console
LARK_APP_ID=cli_a80b4dd39cf9902f

# (required) Lark app secret — keep this value secret, never commit it
LARK_APP_SECRET=your-app-secret-here

# (required) Lark Open-Platform API base URL
LARK_BASE_URL=https://open.larksuite.com/open-apis

# (required) GUID of the Lark Tasklist to poll for new tasks/comments
LARK_TASKLIST_ID=your-tasklist-guid-here

# ─── Access Control ───────────────────────────────────────────────────────────

# (optional) Comma-separated Lark user open_ids allowed to trigger Claude.
# Leave empty to allow all users (no restriction).
# Example: CLAUDE_ALLOW_LIST=ou_abc123,ou_def456
CLAUDE_ALLOW_LIST=

# ─── Storage ──────────────────────────────────────────────────────────────────

# (optional) Path to SQLite queue database.
# Default: /var/lib/claude-vm/queue.db
DB_PATH=/var/lib/claude-vm/queue.db

# (optional) Directory for per-task flock files.
# Default: /var/lib/claude-vm/sessions
LOCK_DIR=/var/lib/claude-vm/sessions

# ─── Polling & Session Limits ─────────────────────────────────────────────────

# (optional) How often to poll Lark for new comments. Go duration string.
# Default: 30s
POLL_INTERVAL=30s

# (optional) Number of turns before injecting /compact into the prompt.
# Default: 50
MAX_TURNS_PER_SESSION=50

# ─── Token Budget Envelope ────────────────────────────────────────────────────

# (required) Server timezone — must be explicit; do not rely on host default.
TZ=Asia/Jakarta

# (optional) Hour (0-23) when the night autonomous-spawn window starts.
# Default: 19 (19:00 WIB)
NIGHT_START=19

# (optional) Hour (0-23, exclusive) when the night window ends.
# Default: 5 (05:00 WIB)
NIGHT_END=5

# (optional) Max random jitter (minutes) added to the 19:00 night start when
# deferring an autonomous row. Must be < (NIGHT_END-NIGHT_START)*60.
# Default: 30
NIGHT_JITTER_MINUTES=30

# (optional) Minutes before the compact watchdog raises an ALERT for a row
# stuck in phase=compact. Default: 30
COMPACT_WATCHDOG_MIN=30

# (optional) Number of stale re-deferrals before a row is moved to DLQ.
# Default: 3
DEFER_COUNT_DLQ=3

# (optional) Number of days to retain turn_usage telemetry rows.
# Default: 30
USAGE_RETENTION_DAYS=30

# ─── Autonomous Implementer (gnhf) ────────────────────────────────────────────

# Path to the gnhf binary on disk. Informational only — the supervisor
# resolves `gnhf` via PATH lookup (see internal/implementer/spawn.go). Setting
# this var does NOT override the lookup; it documents where infra/setup-gnhf.sh
# installs the binary so operators can verify the install.
GNHF_BIN=/usr/local/bin/gnhf

# (required when phase=implement rows arrive) Absolute path to the managed
# git repository on disk. The supervisor creates per-task worktrees off this
# repo and points gnhf at them. With this empty, dispatchImplement falls back
# to the working directory and most calls will fail at the first git command.
IMPLEMENTER_DEFAULT_REPO=/path/to/managed/repo

# (optional) Root directory for per-task git worktrees. The supervisor
# creates one subdirectory per Lark task ID (e.g. .../<taskID>/) and prunes
# them via worktree.Manager.GC().
# Default: /var/lib/claude-vm/worktrees
IMPLEMENTER_WORKTREE_BASE=/var/lib/claude-vm/worktrees

# (optional) When "true" (default), the supervisor invokes `gh pr create`
# after a successful gnhf run with at least one commit. PR URL is recorded
# in implementer_runs.pr_url and included in the Lark thread summary.
# When "false", the supervisor stops at "commits in worktree" and the
# operator opens PRs manually after reviewing the worktree state — useful
# during a canary or when `gh` auth is intentionally unavailable.
# Failed/blocked/timeout/no-progress runs never open PRs regardless.
IMPLEMENTER_AUTO_PR=true

# NOTE — the following implementer knobs are NOT yet wired through the
# supervisor; their values today come from hard-coded defaults in
# internal/implementer/spawn.go (defaultMaxIterations=30, defaultStopWhen,
# defaultTimeout=4h, defaultGracePeriod=30s). Setting them in this env file
# has NO effect. Wiring is M3 follow-up work.
#   IMPLEMENTER_MAX_ITERATIONS  — gnhf --max-iterations cap
#   IMPLEMENTER_STOP_WHEN       — gnhf --stop-when phrase
#   IMPLEMENTER_MAX_TOKENS      — gnhf --max-tokens cap (0 = unbounded)
#   IMPLEMENTER_TIMEOUT         — wall-clock timeout for one spawn
